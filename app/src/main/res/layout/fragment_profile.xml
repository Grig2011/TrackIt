<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <TextView
            android:id="@+id/profileAvatar"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:text="👱"
            android:textSize="45sp"
            android:gravity="center"
            android:background="@drawable/circle_placeholder"
            android:layout_marginTop="16dp"/>

        <TextView
            android:id="@+id/profileName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Guest"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorPrimary"
            android:layout_marginTop="16dp"/>

        <TextView
            android:id="@+id/profileEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="no Email"
            android:textSize="14sp"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginTop="2dp"/>

        <TextView
            android:id="@+id/profileBio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📌 Keep track of your habits, stay motivated, and grow every day!"
            android:textSize="13sp"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:paddingHorizontal="16dp"
            android:alpha="0.8"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PREFERENCES"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="?attr/colorPrimary"
            android:layout_marginTop="32dp"
            android:letterSpacing="0.1"/>

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/themeSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Dark Mode"
            android:paddingVertical="12dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="AI COACH"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="?attr/colorPrimary"
            android:layout_marginTop="24dp"
            android:letterSpacing="0.1"/>

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchAiInsights"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Smart Habit Insights"
            android:paddingVertical="12dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCoachTone"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Coach Personality: Disciplined"
            android:gravity="start"
            android:paddingStart="0dp"
            android:textAllCaps="false"
            android:textColor="?android:attr/textColorPrimary"/>



        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="32dp"
            android:background="?android:attr/dividerVertical"
            android:alpha="0.1"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Logout"
            android:layout_marginTop="16dp"
            android:textColor="?attr/colorPrimary"
            android:textAllCaps="false"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btndelete"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Delete Account"
            android:layout_marginTop="8dp"
            android:textColor="#BA1A1A"
            android:textAllCaps="false"
            android:alpha="0.6"
            android:textSize="12sp"/>

    </LinearLayout>
</ScrollView>