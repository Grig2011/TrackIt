<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5"
    android:padding="16dp">

    <TextView
        android:id="@+id/header1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TrackIt"
        android:textSize="36sp"
        android:textStyle="bold"
        android:layout_gravity="center"/>

    <TextView
        android:id="@+id/header2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Your Habits"
        android:textSize="20sp"
        android:layout_gravity="center"
        android:layout_marginTop="8dp"
        android:textColor="#757575"/>

    <Button
        android:id="@+id/ThemeButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🌙"
        android:layout_gravity="end"
        android:layout_marginTop="16dp"
        app:backgroundTint="#6200EE"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingTop="16dp">

        <LinearLayout
            android:id="@+id/habitsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Habit Card Example -->
            <LinearLayout
                android:id="@+id/HabitCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:strokeColor="#E0E0E0"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/habitIcon1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📕"
                        android:textSize="20sp"
                        android:layout_marginEnd="16dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/habitTitle1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Morning Exercise"
                            android:textSize="18sp"
                            android:textColor="#212121"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/habitDesc1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="30 minutes of exercise"
                            android:textSize="14sp"
                            android:textColor="#757575"
                            android:layout_marginTop="4dp"/>

                        <TextView
                            android:id="@+id/habitStreak1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🔥 5-day streak"
                            android:textSize="12sp"
                            android:textColor="#FF5722"
                            android:layout_marginTop="4dp"/>

                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/habitProgress1"
                            android:layout_width="match_parent"
                            android:layout_height="6dp"
                            android:layout_marginTop="8dp"
                            android:progress="40"
                            app:indicatorColor="#6200EE"
                            app:trackColor="#E0E0E0"
                            app:trackCornerRadius="3dp"
                            app:trackThickness="6dp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
