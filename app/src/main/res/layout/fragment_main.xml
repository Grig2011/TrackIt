<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#EDE7F6"
    android:padding="16dp">

    <!-- Header Section -->
    <LinearLayout
        android:id="@+id/header_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="16dp">

        <TextView
            android:id="@+id/header_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TrackIt"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#4527A0"/>

        <TextView
            android:id="@+id/header_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Stay consistent, see progress"
            android:textSize="16sp"
            android:textColor="#5E35B1"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <!-- Scrollable Habit List -->
    <ScrollView
        android:id="@+id/habit_scrollview"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never">

        <LinearLayout
            android:id="@+id/habits_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Habit Card 1: Morning Meditation -->
            <androidx.cardview.widget.CardView
                android:id="@+id/habitCard1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="10dp"
                android:background="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical">

                    <!-- Left colored indicator -->
                    <View
                        android:layout_width="6dp"
                        android:layout_height="match_parent"
                        android:background="#7E57C2"
                        android:layout_marginEnd="16dp"/>

                    <!-- Content -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/habitTitle1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Morning Meditation"
                            android:textSize="18sp"
                            android:textColor="#311B92"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/habitDesc1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🧘‍♂️ 15 min daily mindfulness"
                            android:textSize="14sp"
                            android:textColor="#5E35B1"
                            android:layout_marginTop="4dp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="8dp"
                            >

                            <TextView
                                android:id="@+id/habitStreak1"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🔥 6-day streak"
                                android:textSize="12sp"
                                android:textColor="#FF7043"/>

                            <TextView
                                android:id="@+id/habitTime1"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="06:30 AM"
                                android:textSize="12sp"
                                android:textColor="#9C27B0"/>
                        </LinearLayout>

                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/habitProgress1"
                            android:layout_width="match_parent"
                            android:layout_height="10dp"
                            android:layout_marginTop="8dp"
                            android:progress="50"
                            app:indicatorColor="#673AB7"
                            app:trackColor="#D1C4E9"
                            app:trackCornerRadius="5dp"
                            app:trackThickness="10dp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Habit Card 2: Drink Water -->
            <androidx.cardview.widget.CardView
                android:id="@+id/habitCard2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="10dp"
                android:background="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical">

                    <View
                        android:layout_width="6dp"
                        android:layout_height="match_parent"
                        android:background="#29B6F6"
                        android:layout_marginEnd="16dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/habitTitle2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Drink Water"
                            android:textSize="18sp"
                            android:textColor="#0277BD"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/habitDesc2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💧 8 glasses daily"
                            android:textSize="14sp"
                            android:textColor="#0288D1"
                            android:layout_marginTop="4dp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="8dp"
                            >

                            <TextView
                                android:id="@+id/habitStreak2"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🔥 7-day streak"
                                android:textSize="12sp"
                                android:textColor="#039BE5"/>

                            <TextView
                                android:id="@+id/habitTime2"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="08:00 AM"
                                android:textSize="12sp"
                                android:textColor="#0288D1"/>
                        </LinearLayout>

                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/habitProgress2"
                            android:layout_width="match_parent"
                            android:layout_height="10dp"
                            android:layout_marginTop="8dp"
                            android:progress="75"
                            app:indicatorColor="#03A9F4"
                            app:trackColor="#B3E5FC"
                            app:trackCornerRadius="5dp"
                            app:trackThickness="10dp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Habit Card 3: Read Book -->
            <androidx.cardview.widget.CardView
                android:id="@+id/habitCard3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="10dp"
                android:background="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical">

                    <View
                        android:layout_width="6dp"
                        android:layout_height="match_parent"
                        android:background="#FF7043"
                        android:layout_marginEnd="16dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/habitTitle3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Read Book"
                            android:textSize="18sp"
                            android:textColor="#E64A19"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/habitDesc3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📖 20 pages daily"
                            android:textSize="14sp"
                            android:textColor="#FF5722"
                            android:layout_marginTop="4dp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="8dp"
                            >

                            <TextView
                                android:id="@+id/habitStreak3"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🔥 3-day streak"
                                android:textSize="12sp"
                                android:textColor="#FF7043"/>

                            <TextView
                                android:id="@+id/habitTime3"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="09:00 PM"
                                android:textSize="12sp"
                                android:textColor="#E64A19"/>
                        </LinearLayout>

                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/habitProgress3"
                            android:layout_width="match_parent"
                            android:layout_height="10dp"
                            android:layout_marginTop="8dp"
                            android:progress="30"
                            app:indicatorColor="#FF5722"
                            app:trackColor="#FFCCBC"
                            app:trackCornerRadius="5dp"
                            app:trackThickness="10dp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</LinearLayout>