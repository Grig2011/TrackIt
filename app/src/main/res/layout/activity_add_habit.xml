<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".AddHabit">

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="32dp">

            <!-- Back Button (escaped "<") -->
            <Button
                android:id="@+id/backBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&lt;-- back"
                android:backgroundTint="#6200EE"
                android:textColor="#FFFFFF"/>

            <!-- Emoji -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Emoji"
                android:textSize="16sp"
                android:layout_marginTop="8dp"/>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Enter an emoji">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/emojiInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxLength="2"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Title"
                android:textSize="16sp"
                android:layout_marginTop="16dp"/>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Habit Title">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/titleInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Description -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Description"
                android:textSize="16sp"
                android:layout_marginTop="16dp"/>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Habit Description">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/descInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textMultiLine"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Colour -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Colour"
                android:textSize="16sp"
                android:layout_marginTop="16dp"/>
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/Purple"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_marginStart="0dp"
                    android:text=""
                    app:cornerRadius="28dp"
                    android:backgroundTint="#6200EE"
                    android:foreground="?attr/selectableItemBackground"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/Green"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_marginStart="10dp"
                    android:text=""
                    app:cornerRadius="28dp"
                    android:backgroundTint="#32A852"
                    android:foreground="?attr/selectableItemBackground"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/Red"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_marginStart="10dp"
                    android:text=""
                    app:cornerRadius="28dp"
                    android:backgroundTint="#F51111"
                    android:foreground="?attr/selectableItemBackground"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/Orange"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_marginStart="10dp"
                    android:text=""
                    app:cornerRadius="28dp"
                    android:backgroundTint="#EB8F34"
                    android:foreground="?attr/selectableItemBackground"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/Blue"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_marginStart="10dp"
                    android:text=""
                    app:cornerRadius="28dp"
                    android:backgroundTint="#2962FF"
                    android:foreground="?attr/selectableItemBackground"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/Yellow"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_marginStart="10dp"
                    android:text=""
                    app:cornerRadius="28dp"
                    android:backgroundTint="#FFD600"
                    android:foreground="?attr/selectableItemBackground"/>
            </LinearLayout>

            <!-- Second row of 6 additional colors -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/Pink"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:text=""
                    app:cornerRadius="28dp"
                    android:backgroundTint="#FF4081"
                    android:foreground="?attr/selectableItemBackground"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/Cyan"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_marginStart="10dp"
                    android:text=""
                    app:cornerRadius="28dp"
                    android:backgroundTint="#00BCD4"
                    android:foreground="?attr/selectableItemBackground"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/Lime"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_marginStart="10dp"
                    android:text=""
                    app:cornerRadius="28dp"
                    android:backgroundTint="#CDDC39"
                    android:foreground="?attr/selectableItemBackground"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/DeepOrange"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_marginStart="10dp"
                    android:text=""
                    app:cornerRadius="28dp"
                    android:backgroundTint="#FF5722"
                    android:foreground="?attr/selectableItemBackground"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/Indigo"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_marginStart="10dp"
                    android:text=""
                    app:cornerRadius="28dp"
                    android:backgroundTint="#3F51B5"
                    android:foreground="?attr/selectableItemBackground"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/Brown"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_marginStart="10dp"
                    android:text=""
                    app:cornerRadius="28dp"
                    android:backgroundTint="#795548"
                    android:foreground="?attr/selectableItemBackground"/>
            </LinearLayout>
            <!-- Habit Type -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Habit Type"
                android:textSize="16sp"
                android:layout_marginTop="16dp"/>

            <Spinner
                android:id="@+id/typeSpinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:entries="@array/habit_type"/>

            <!-- Goal Value -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Goal Value"
                android:textSize="16sp"
                android:layout_marginTop="16dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:hint="Enter value">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/goalInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"/>
                </com.google.android.material.textfield.TextInputLayout>

                <Spinner
                    android:id="@+id/unitSpinner"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:entries="@array/goal_units"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>

            <!-- Task Days -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Task Days"
                android:textSize="16sp"
                android:layout_marginTop="16dp"/>

            <Spinner
                android:id="@+id/daysSpinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:entries="@array/task_days"/>

            <!-- Save Button -->
            <Button
                android:id="@+id/saveHabitBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Save Habit"
                android:layout_marginTop="24dp"
                android:backgroundTint="#6200EE"
                android:textColor="#FFFFFF"/>

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
