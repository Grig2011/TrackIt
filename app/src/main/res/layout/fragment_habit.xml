<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EDE7F6"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <TextView
            android:id="@+id/habitsHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Popular Habits"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#4527A0"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp"/>

        <!-- Habit Card Example -->
        <androidx.cardview.widget.CardView
            android:id="@+id/habitCard1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp"
            android:clickable="true"
            android:foreground="?attr/selectableItemBackground"
            android:background="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/habitIcon1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🧘‍♂️"
                    android:textSize="28sp"
                    android:layout_marginEnd="16dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/habitTitle1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Morning Meditation"
                        android:textSize="18sp"
                        android:textColor="#311B92"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/habitDesc1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🧘‍♂️ 15 min daily mindfulness"
                        android:textSize="14sp"
                        android:textColor="#5E35B1"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/habitAddIcon1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="➕"
                    android:textSize="24sp"
                    android:textColor="#4527A0"
                    android:layout_marginStart="12dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Habit Card 2: Drink Water -->
        <androidx.cardview.widget.CardView
            android:id="@+id/habitCard2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp"
            android:clickable="true"
            android:foreground="?attr/selectableItemBackground"
            android:background="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/habitIcon2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💧"
                    android:textSize="28sp"
                    android:layout_marginEnd="16dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/habitTitle2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Drink Water"
                        android:textSize="18sp"
                        android:textColor="#0277BD"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/habitDesc2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💧 8 glasses daily"
                        android:textSize="14sp"
                        android:textColor="#0288D1"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/habitAddIcon2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="➕"
                    android:textSize="24sp"
                    android:textColor="#4527A0"
                    android:layout_marginStart="12dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Habit Card 3: Read Book -->
        <androidx.cardview.widget.CardView
            android:id="@+id/habitCard3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp"
            android:clickable="true"
            android:foreground="?attr/selectableItemBackground"
            android:background="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/habitIcon3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📖"
                    android:textSize="28sp"
                    android:layout_marginEnd="16dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/habitTitle3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Read Book"
                        android:textSize="18sp"
                        android:textColor="#E64A19"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/habitDesc3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📖 20 pages daily"
                        android:textSize="14sp"
                        android:textColor="#FF5722"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/habitAddIcon3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="➕"
                    android:textSize="24sp"
                    android:textColor="#4527A0"
                    android:layout_marginStart="12dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Habit Card 4: Evening Walk -->
        <androidx.cardview.widget.CardView
            android:id="@+id/habitCard4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp"
            android:clickable="true"
            android:foreground="?attr/selectableItemBackground"
            android:background="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/habitIcon4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🚶‍♂️"
                    android:textSize="28sp"
                    android:layout_marginEnd="16dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/habitTitle4"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Evening Walk"
                        android:textSize="18sp"
                        android:textColor="#388E3C"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/habitDesc4"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="30 min walk"
                        android:textSize="14sp"
                        android:textColor="#43A047"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/habitAddIcon4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="➕"
                    android:textSize="24sp"
                    android:textColor="#4527A0"
                    android:layout_marginStart="12dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>