    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <TextView
            android:id="@+id/habitsHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Popular Habits"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/primary_color"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp"/>

        <!-- Habit Card Example -->


            <!-- Habit Card 5: Morning Stretch -->
            <androidx.cardview.widget.CardView
                android:id="@+id/habitCard5"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp"
                android:clickable="true"
                android:foreground="?attr/selectableItemBackground"
                android:background="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/habitIcon5"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🤸‍♂️"
                        android:textSize="28sp"
                        android:layout_marginEnd="16dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/habitTitle5"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Morning Stretch"
                            android:textSize="18sp"
                            android:textColor="#F57F17"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/habitDesc5"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Wake up your body in 10 minutes"
                            android:textSize="14sp"
                            android:textColor="#F9A825"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/habitAddIcon5"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="➕"
                        android:textSize="24sp"
                        android:textColor="#4527A0"
                        android:layout_marginStart="12dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

