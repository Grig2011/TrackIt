<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="12dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/habit_bg_color">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Background buttons on LEFT -->
        <LinearLayout
            android:id="@+id/backgroundButtons"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="start|center_vertical"
            android:paddingStart="0dp">

            <ImageButton
                android:id="@+id/editButton"
                android:layout_width="60dp"
                android:layout_height="match_parent"
                android:background="@color/primary_color"
            android:src="@drawable/baseline_edit_24"
            android:contentDescription="Edit"
            app:tint="@color/text_secondary" />

            <ImageButton
                android:id="@+id/deleteButton"
                android:layout_width="60dp"
                android:layout_height="match_parent"
                android:background="@color/red_delete"
            android:src="@drawable/outline_delete_24"
            android:contentDescription="Delete"
            app:tint="@color/text_secondary" />
        </LinearLayout>

        <!-- Foreground: card content -->
        <LinearLayout
            android:id="@+id/cardContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <View
                android:id="@+id/colorBar"
                android:layout_width="8dp"
                android:layout_height="match_parent"
                android:background="@color/purple_700" /> <!-- use your purple color -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/habitTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Habit title"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:id="@+id/habitDesc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Habit description"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="4dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <TextView
                        android:id="@+id/habitGoal"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Goal"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/Strak"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔥 Streak"
                        android:textSize="13sp"
                        android:textColor="@color/orange_streak" />
                </LinearLayout>

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/habitProgress"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="12dp"
                    android:progress="40"
                    app:indicatorColor="@color/purple_700"
                    app:trackColor="@color/track_gray"
                    app:trackCornerRadius="6dp"
                    app:trackThickness="8dp" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>
</androidx.cardview.widget.CardView>