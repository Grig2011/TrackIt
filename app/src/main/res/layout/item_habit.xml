<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/habit_bg_color">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Background buttons (fixed) -->
        <LinearLayout
            android:id="@+id/backgroundButtons"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="start|center_vertical"
            android:paddingStart="0dp">

            <!-- Edit button -->
            <ImageButton
                android:id="@+id/editButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="4dp"
                android:background="@drawable/btn_circle_bg"
                android:src="@drawable/baseline_edit_24"
                android:contentDescription="Edit"
                app:tint="@color/text_primary" />

            <!-- Delete button -->
            <ImageButton
                android:id="@+id/deleteButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/btn_circle_bg"
                android:src="@drawable/outline_delete_24"
                android:contentDescription="Delete"
                android:backgroundTint="#ff0000"
                android:tint="@color/text_primary"/>
        </LinearLayout>

        <!-- Foreground content (this moves with swipe) -->
        <LinearLayout
            android:id="@+id/cardContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@android:color/transparent">

            <!-- Small color bar -->
            <View
                android:id="@+id/colorBar"
                android:layout_width="6dp"
                android:layout_height="match_parent"
                android:background="@color/purple_700" />

            <!-- Content container -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:id="@+id/habitTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Habit title"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:id="@+id/habitDesc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Habit description"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="2dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="6dp">

                    <TextView
                        android:id="@+id/habitGoal"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Goal"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/Strak"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔥 Streak"
                        android:textSize="12sp"
                        android:textColor="@color/orange_streak" />
                </LinearLayout>

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/habitProgress"
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:layout_marginTop="8dp"
                    android:progress="40"
                    app:indicatorColor="@color/purple_700"
                    app:trackColor="@color/track_gray"
                    app:trackCornerRadius="4dp"
                    app:trackThickness="6dp" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>
</androidx.cardview.widget.CardView>